{
  "name": "june-ar-bp-cuff",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Production-grade WebXR optical see-through AR blood pressure cuff training visualization. PlayCanvas standalone + TypeScript + Vite. No Unity.",
  "scripts": {
