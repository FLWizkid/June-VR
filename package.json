    "playcanvas": "^2.19.7",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/webxr": "^0.5.24",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
